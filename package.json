{
  "name": "globalcare-backend",
  "version": "1.0.0",
  "description": "Global Care Medical Tourism Management Platform — Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrations/run.js",
    "seed": "node migrations/seed.js",
    "test": "jest --coverage",
    "build": "rimraf dist && cpy \"**/*\" dist --exclude=node_modules --exclude=.env",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "deploy": "npm run build && npm run pm2:start"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "nodemailer": "^6.9.7",
    "redis": "^4.6.10",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  }
}
